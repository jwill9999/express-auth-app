# Server Configuration
PORT=3000
NODE_ENV=development

# Database Configuration
# For local development (non-Docker): mongodb://localhost:27017/auth-app
# For Docker: mongodb://admin:password123@localhost:27017/auth_db?authSource=admin
MONGODB_URI=mongodb://localhost:27017/auth-app

# JWT Configuration
JWT_SECRET=your-secret-key-change-this-in-production
JWT_EXPIRES_IN=24h

# Google OAuth Configuration
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_CALLBACK_URL=http://localhost:3000/auth/google/callback

# Session Configuration
SESSION_SECRET=your-session-secret-change-this

# Rate Limiting (set to false to disable, e.g. during local development)
# RATE_LIMIT_ENABLED=true
