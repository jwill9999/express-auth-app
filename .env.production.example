# Production Environment Configuration
# Copy this file to .env.production and fill in real values.
# NEVER commit .env.production to git.

# Server Configuration
PORT=3000
NODE_ENV=production

# Frontend Configuration
FRONTEND_URL=https://yourdomain.com

# Traefik / Domain Configuration
APP_DOMAIN=yourdomain.com
TRAEFIK_ACME_EMAIL=admin@yourdomain.com

# Database Configuration
# Use a strong, unique password — do not reuse the dev password.
MONGODB_URI=mongodb://admin:STRONG_PASSWORD_HERE@mongodb:27017/auth_db?authSource=admin

# JWT Configuration
# Generate with: openssl rand -hex 64
JWT_SECRET=REPLACE_WITH_STRONG_SECRET
JWT_EXPIRES_IN=24h

# Google OAuth Configuration
GOOGLE_CLIENT_ID=your-production-google-client-id
GOOGLE_CLIENT_SECRET=your-production-google-client-secret
GOOGLE_CALLBACK_URL=https://yourdomain.com/auth/google/callback

# Session Configuration
# Generate with: openssl rand -hex 64
SESSION_SECRET=REPLACE_WITH_STRONG_SECRET

# Rate Limiting (always enabled in production)
RATE_LIMIT_ENABLED=true
